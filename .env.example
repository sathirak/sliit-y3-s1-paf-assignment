# ==========================================
# Smart Campus — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️ NEVER commit .env to GitHub (it's already in .gitignore)
# ==========================================

# ---- MongoDB Atlas (REQUIRED) ----
# Get this from: MongoDB Atlas → Connect → Drivers → Connection String
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/smart_campus?retryWrites=true&w=majority

# ---- JWT Secret (REQUIRED) ----
# Any long random string (min 256 bits / 32+ characters)
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLongSmartCampus2026

# ---- Google OAuth (OPTIONAL — needed for Google Sign-In) ----
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- Email / Mailtrap (OPTIONAL — needed for email notifications) ----
# Get from: https://mailtrap.io → Inboxes → SMTP Settings
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
